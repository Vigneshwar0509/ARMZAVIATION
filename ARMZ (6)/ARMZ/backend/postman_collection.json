{
  "info": {
    "name": "ARMZ Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"role\": \"student\"\n}"
        }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('accessToken', data.token);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Login Student",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('accessToken', data.token);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Login Employer",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"employer@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('accessToken', data.token);",
              "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) pm.collectionVariables.set('accessToken', data.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/auth/logout",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Admin Portal Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/admin/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"rkpk110011@gmail.com\",\n  \"password\": \"AdminPass123!\"\n}"
        }
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/auth/profile"
      }
    },
    {
      "name": "Admin List Users",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/users"
      }
    },
    {
      "name": "Admin List Admins",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/admins"
      }
    },
    {
      "name": "Admin Update User Subscription",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/users/update-subscription",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"student@example.com\",\n  \"planId\": \"premium\"\n}"
        }
      }
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Get Jobs",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/jobs"
      }
    },
    {
      "name": "Get Plans",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/plans"
      }
    },
    {
      "name": "Contact Submit",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/contact",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Aviation Candidate\",\n  \"email\": \"candidate@example.com\",\n  \"phone\": \"+918220551116\",\n  \"subject\": \"Program Inquiry\",\n  \"message\": \"I want to know more about ARMZ programs.\"\n}"
        }
      }
    },
    {
      "name": "Create Payment Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/payments/create-order",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"planId\": \"1\",\n  \"amount\": 19900,\n  \"currency\": \"INR\"\n}"
        }
      }
    }
  ]
}
