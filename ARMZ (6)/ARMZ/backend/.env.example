# Backend environment configuration example
# Copy this file to .env and fill in secret values for local or deployment use.

DEBUG=True
SECRET_KEY=replace-me-with-a-secure-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Production frontend origin(s) for deployed React app.
# If frontend and backend share the same host, you can leave CORS_ALLOWED_ORIGINS blank
# and use a relative API path from the browser (e.g. /api).
# Example for a separate frontend domain:
# CORS_ALLOWED_ORIGINS=https://app.example.com
# CSRF_TRUSTED_ORIGINS=https://app.example.com

DATABASE_ENGINE=django.db.backends.mysql
DATABASE_URL=mysql://armz:armz@mysql:3306/armz
MYSQL_DB=armz
MYSQL_USER=armz
MYSQL_PASSWORD=armz
MYSQL_HOST=mysql
MYSQL_PORT=3306
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@armz.example
CONTACT_INBOX_EMAIL=support@armz.example
EMAIL_FAIL_SILENTLY=False
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
AWS_REGION=us-east-1
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM_NAME=ARMZ
SMS_FAIL_SILENTLY=False

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

SENTRY_DSN=
GOOGLE_CLIENT_IDS=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Tenant and API
TENANT_API_KEY=
