# Frontend environment configuration example
# Copy this file to .env and configure public runtime values.

# Use the backend API base URL for local development:
VITE_API_BASE_URL=http://localhost:8000/api

# In production, when React is served from the same domain and
# Nginx proxies /api/ to the Django backend, use:
# VITE_API_URL=/api

VITE_APP_NAME=ARMZ
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_SIGN_IN_ENABLED=true
VITE_RAZORPAY_KEY_ID=
VITE_ENABLE_ANALYTICS=false
VITE_FRONTEND_ONLY=false
